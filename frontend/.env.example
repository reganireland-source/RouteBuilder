# RouteBuilder frontend environment variables
# Copy this file to .env.local and fill in values for local development

# Backend API URL (required)
VITE_API_URL=http://localhost:8000

# App password for viewer access (required)
VITE_APP_PASSWORD=

# Enable NLP natural-language routing (optional, default: false)
VITE_ENABLE_NLP=false

# Map tile provider: 'osm' uses CARTO tiles (default), 'google' uses Google Maps
# Google Maps requires a valid API key with Maps JavaScript API enabled
VITE_MAPS_PROVIDER=osm

# Google Maps API key — only required when VITE_MAPS_PROVIDER=google
# Create a key at https://console.cloud.google.com/  → APIs & Services → Credentials
# Enable: Maps JavaScript API
VITE_GMAPS_API_KEY=
