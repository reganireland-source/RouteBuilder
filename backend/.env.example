# ──────────────────────────────────────────────────────────────────────────────
# RouteBuilder Backend — Environment Variables
# Copy this file to .env and fill in values before starting the server.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. If not set, app falls back to local JSON files
# (single-user dev mode only — not suitable for production).
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/routebuilder

# ── Access Control ────────────────────────────────────────────────────────────
# Admin passphrase for write operations (create/update/delete data).
# Users without this key can view all data but cannot make changes.
# If not set, the app runs in open mode (everyone can edit — dev/internal only).
# Replace this with a strong random secret in production.
# Generate one with: openssl rand -base64 32
ADMIN_KEY=change-me-before-production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Set to your frontend domain(s) in production. Default ("*") is insecure.
# Example: ALLOWED_ORIGINS=https://routebuilder.yourcompany.com
ALLOWED_ORIGINS=*

# ── NLP / TSABuddy ────────────────────────────────────────────────────────────
# Set to "true" to enable natural language route search.
NLP_ENABLED=false

# Provide exactly ONE of the following API keys to enable NLP.
# Claude (Anthropic) — recommended
ANTHROPIC_API_KEY=

# Azure OpenAI — enterprise option
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# OpenAI direct
OPENAI_API_KEY=
